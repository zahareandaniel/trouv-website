# Vercel: Project → Settings → Environment Variables
#
# ── AI Chat (required) ───────────────────────────────────────────────────────
# Create an API key at https://platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxx

# ── Rate limiting (optional — chat works without it, just unthrottled) ───────
# Create a Redis database at https://upstash.com and copy the REST credentials.
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxx

# ── Contact form & lead emails (required for email delivery) ─────────────────
# 1) Create https://resend.com account, verify DNS for trouv.co.uk, create an API key.
# 2) Use a "from" address on your verified domain (example below).
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=info@trouv.co.uk
CONTACT_FROM_EMAIL=Trouv Website <website@trouv.co.uk>

# ── Pricing / distance (optional — falls back to postcode table without it) ──
GOOGLE_MAPS_API_KEY=your_google_maps_key_here